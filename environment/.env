# SpeakMaster 环境变量配置
# 供 docker-compose 和各服务使用

# MySQL
DB_HOST=localhost
DB_PORT=3307
DB_ROOT_PASSWORD=root

# Redis (单机模式)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# JWT (所有服务必须使用相同密钥)
JWT_SECRET=your-very-secure-secret-key-should-be-at-least-256-bits-long

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
