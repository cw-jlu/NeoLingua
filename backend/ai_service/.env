# AI Service 环境变量配置

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8089
DEBUG=true

# AI Gateway配置（模型推理通过AI Gateway调用）
AI_GATEWAY_URL=http://localhost:8088
AI_GATEWAY_CHAT_PATH=/api/v1/user/ai/chat
AI_GATEWAY_STREAM_PATH=/api/v1/user/ai/chat/stream
AI_GATEWAY_STOP_PATH=/api/v1/user/ai/chat/stop
AI_GATEWAY_MODELS_PATH=/api/v1/user/ai/models

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=8

# Milvus配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=ai_memory

# ===== Embedding 配置 =====
# provider 选项: gemini | openai | ollama
EMBEDDING_PROVIDER=gemini
EMBEDDING_DIM=768

# Gemini embedding (text-embedding-004, 768维)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# OpenAI 兼容 embedding (备用)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama embedding (本地降级)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# 记忆配置
SHORT_TERM_TTL=3600
MAX_CONTEXT_MESSAGES=20
