# Analysis Service 环境变量配置

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8085
DEBUG=true
# MySQL配置
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=speakmaster_analysis
DB_USER=root
DB_PASSWORD=root
# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=5

# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=analysis-worker-group
KAFKA_TOPIC_DIALOGUE=stream.dialogue.text
KAFKA_TOPIC_RESULT=stream.analysis.result

# MinIO配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=speakmaster-audio
MINIO_SECURE=false

# MFA配置（发音分析，独立conda环境，避免依赖冲突）
MFA_PYTHON_PATH=
MFA_DICTIONARY_PATH=
MFA_ACOUSTIC_MODEL_PATH=

# 音频本地存储路径
AUDIO_STORAGE_PATH=./audio_files
